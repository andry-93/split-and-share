{
  "expo": {
    "name": "Split & Share",
    "slug": "split-and-share",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "jsEngine": "hermes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ecf7fa",
      "dark": {
        "backgroundColor": "#081633"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.splitandshare",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "Allow Split & Share to access your contacts so you can quickly add people."
      }
    },
    "android": {
      "ndkVersion": "29.0.14206865",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ecf7fa",
        "dark": {
          "backgroundColor": "#081633"
        }
      },
      "splash": {
        "backgroundColor": "#ecf7fa",
        "dark": {
          "backgroundColor": "#081633"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.splitandshare",
      "permissions": [
        "READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "18b4e745-ddf3-42fa-81c1-2d194d29c305"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ecf7fa",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#081633"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "29.0.14206865"
          }
        }
      ]
    ]
  }
}
